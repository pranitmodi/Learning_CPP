{
    "files.associations": {
        "*.ejs": "html",
        "iostream": "cpp",
        "ostream": "cpp",
        "vector": "cpp",
        "array": "cpp",
        "bitset": "cpp",
        "initializer_list": "cpp",
        "regex": "cpp",
        "utility": "cpp",
        "valarray": "cpp",
        "deque": "cpp",
        "forward_list": "cpp",
        "list": "cpp",
        "string": "cpp",
        "unordered_map": "cpp",
        "unordered_set": "cpp"
    },
    "files.exclude": {
        "**/*.exe": true,
        "**/*.out": true,
        "**/*.class": true,
        "**/hello": true,
        "**/datatypes": true,
        "**/implicit_type_casting": true
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.cpp": "${capture}, ${capture}.exe, ${capture}.out, ${capture}.class"
    },
    "C_Cpp.errorSquiggles": "disabled"
}